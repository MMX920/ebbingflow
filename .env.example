# ===================================================
# EbbingFlow 环境变量配置 (通用 OpenAI 兼容模式)
# ===================================================

# --- 1. 大模型 (LLM) 接入配置 ---
# 默认配置：通用的 OpenAI 兼容接口 (可切换为 硅基、火山、DeepSeek 等)

# 【默认选项：通用的 OpenAI 兼容配置】
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 【备选方案 A：本地 Ollama】
# OPENAI_API_KEY=sk-no-key-required
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:7b

# 【备选方案 B：硅基流动 (SiliconFlow)】
# OPENAI_API_KEY=sk-your-siliconflow-key
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL=deepseek-ai/DeepSeek-V3

# --- 2. 嵌入模型 (Embedding) 接入配置 ---
# 支持 Local (SentenceTransformers), Ollama, OpenAI

# 【方案 A：完全本地 (SentenceTransformers) - 默认】
EMBED_TYPE=local
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 【方案 B：Ollama 本地嵌入】
# EMBED_TYPE=ollama
# EMBED_MODEL=nomic-embed-text
# EMBED_BASE_URL=http://localhost:11434/v1
# EMBED_API_KEY=sk-no-key-required

# 【方案 C：OpenAI / 硅基流动 兼容嵌入】
# EMBED_TYPE=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-your-key-here

# --- 3. Neo4j 数据库 ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# --- 4. 共享 PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ebbingflow
POSTGRES_USER=ebbingflow
POSTGRES_PASSWORD=your_password
TENANT_ID=your_tenant_id

# --- 5. 运行参数微调 ---
MEMORY_WINDOW_SIZE=3              # 对话窗口历史轮数
EVENT_CONFIDENCE_THRESHOLD=0.7    # 记忆入库置信度门槛
LLM_TIMEOUT=60.0                  # 模型响应超时 (秒)
LLM_MAX_RETRIES=2                 # 失败自动重试次数

# --- 6. 人格推断调度 ---
INFERENCE_MIN_EVIDENCE=3          # 自动推断最少证据条数
INFERENCE_AUTO_INTERVAL=6         # 每 N 轮对话自动执行一次人格重判

# --- 7. WebSocket Authentication (Recommended for production) ---
WS_AUTH_REQUIRED=false
WS_AUTH_TOKEN=
WS_AUTH_QUERY_PARAM=ws_token
MAINTENANCE_TOKEN=

# QQ Bot 配置
QQ_BOT_APPID=your_APPID
QQ_BOT_SECRET=your_TOKEN
